  "keyFeatures": [
    "Firewall policy management with compilation support for IPTables, NFTables, and VyOS",
    "Multi-VPN support (OpenVPN, WireGuard, IPsec/strongSwan)",
    "Policy rule compilation and deployment to remote firewalls",
    "Routing table and rule management",
    "System service configuration (DHCP, Keepalived, HAProxy)",
    "Certificate authority and certificate management",
    "Automated backup and restore with scheduled backups",
    "Snapshot management for configuration versioning",
    "AI-powered policy analysis and validation",
    "Two-factor authentication support",
    "Real-time communication via WebSockets",
    "Import/export functionality for iptables-save format",
    "Exclusive write access control for multi-user environments",
    "Plugin system for firewall extensions"
  ],
  "publicApiSurface": [
    "POST /fwclouds - Create FWCloud",
    "PUT /fwclouds/:fwcloud - Update FWCloud",
    "POST /fwclouds/:fwcloud/firewalls/communication/ping - Ping firewall",
    "POST /fwclouds/:fwcloud/firewalls/communication/info - Get firewall info",
    "GET /fwclouds/:fwcloud/firewalls/:firewall/policyRules/read - Read policy rules",
    "POST /fwclouds/:fwcloud/firewalls/:firewall/policyRules/download - Compile and download policy",
    "POST /fwclouds/:fwcloud/firewalls/:firewall/openvpns/:openvpn/installer - Install OpenVPN",
    "POST /fwclouds/:fwcloud/firewalls/:firewall/wireguards/:wireguard/installer - Install WireGuard",
    "POST /fwclouds/:fwcloud/firewalls/:firewall/ipsecs/:ipsec/installer - Install IPsec",
    "POST /vpn/wireguard - Create WireGuard VPN",
    "POST /vpn/ipsec - Create IPsec VPN",
    "GET /fwclouds/:fwcloud/firewalls/:firewall/routingTables - List routing tables",
    "POST /fwclouds/:fwcloud/firewalls/:firewall/routingTables/:routingTable/routes - Create route",
    "POST /fwclouds/:fwcloud/firewalls/:firewall/AIassistant - Check policy with AI",
    "GET /backups - List backups",
    "POST /backups - Create backup",
    "POST /backups/:backup/restore - Restore backup",
    "GET /snapshots - List snapshots",
    "POST /snapshots - Create snapshot",
    "POST /snapshots/:snapshot/restore - Restore snapshot",
    "POST /profile/tfa/setup - Setup two-factor authentication",
    "POST /profile/tfa/verify - Verify TFA token",
    "GET /aiassistant - Get AI assistant configuration",
    "PUT /aiassistant - Update AI assistant configuration",
    "GET /version - Get API version",
    "GET /updates - Check for updates",
    "PUT /updates/api - Update API",
    "PUT /iptables-save/import - Import iptables-save format",
    "PUT /iptables-save/export - Export to iptables-save format"
  ]
}
